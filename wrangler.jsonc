{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Cloudflare Pages static site — no Worker entrypoint, no assets binding.
  // Dashboard (Workers & Pages → parama → Settings → Builds):
  //   Build command: node scripts/workers-ci-build.mjs
  //   Build output directory: public
  //   Deploy command: npx wrangler pages deploy public --project-name=parama
  // Do NOT use: npx wrangler deploy
  "name": "parama",
  "pages_build_output_dir": "public"
}
